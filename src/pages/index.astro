---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import ProjectCard from '@components/ProjectCard.astro';
import BlogCard from '@components/BlogCard.astro';
import LabUpdate from '@components/LabUpdate.astro';
import { SITE } from '@lib/site';
import { labUpdates } from '@data/labUpdates';
const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
---
<BaseLayout>
  <section class="hero"><div class="container hero-grid"><div class="hero-copy"><h1>Refurbished tech, homelab builds, and practical <span>AI automation</span></h1><p>Real-world projects, build notes, and automation solutions from our lab to yours.</p><div class="hero-actions"><a class="button" href="/projects/">View projects</a><a class="button button-ghost" href={SITE.storeUrl} target="_blank" rel="noopener">Visit store</a></div></div><figure class="hero-media"><img src="/images/hero-lab.svg" alt="Refurbished workstations and homelab equipment in an IT workshop" width="1200" height="720" loading="eager" /></figure></div></section>
  <section class="section"><div class="container section-header"><div><h2>Project Showcase</h2><p>Operational tools and lab builds that turn repeat work into reliable systems.</p></div><a class="text-link" href="/projects/">All projects</a></div><div class="container project-grid">{projects.slice(0,6).map((project) => <ProjectCard title={project.data.title} summary={project.data.summary} status={project.data.status} stack={project.data.stack} href={`/projects/${project.id}/`} featured={project.data.featured} />)}</div></section>
  <section class="section dark-band"><div class="container section-header"><div><h2>Latest from the blog</h2><p>Short, practical writeups from the retail floor, workshop bench, and automation stack.</p></div><a class="text-link" href="/blog/">Read the blog</a></div><div class="container blog-list">{posts.map((post) => <BlogCard post={post} />)}</div></section>
  <section class="section"><div class="container lab-grid"><div class="section-header stacked"><h2>Lab Updates</h2><p>Notes from storage, monitoring, refurbished hardware testing, and local AI experiments.</p><a class="button button-ghost" href="/lab/">Open lab log</a></div><div class="lab-list">{labUpdates.map((update) => <LabUpdate {...update} />)}</div></div></section>
  <section class="section about-preview"><div class="container about-preview-grid"><img src="/images/hero-lab.svg" alt="XtremeSystem workshop bench and homelab hardware" width="1200" height="720" loading="lazy" /><div><h2>About XtremeSystem</h2><p>We document the practical systems work behind refurbished computers, IT retail operations, lab infrastructure, and AI-assisted workflows.</p><a class="text-link" href="/about/">More about the lab</a></div></div></section>
  <section class="section contact-strip"><div class="container contact-strip-inner"><div><h2>Need refurbished hardware or IT service?</h2><p>Contact the retail team through the main Xtreme Systems store.</p></div><a class="button" href={SITE.storeUrl} target="_blank" rel="noopener">xtremesystems.co.nz</a></div></section>
</BaseLayout>

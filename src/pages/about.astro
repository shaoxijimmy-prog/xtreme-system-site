---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE } from '@lib/site';
---
<BaseLayout title="About" description="About XtremeSystem, a practical technology site for refurbished computers, IT retail systems, homelab builds, and AI automation.">
  <section class="page-hero compact"><div class="container"><h1>About XtremeSystem</h1><p>XtremeSystem documents the systems work behind refurbished computers, IT retail operations, homelab infrastructure, and practical AI automation.</p></div></section>
  <section class="section about-grid-section"><div class="container about-grid"><div><h2>Built from real shop workflows</h2><p>The site keeps track of useful experiments: product data cleanup, inventory automation, storage reliability, monitoring, and local AI tooling that can be used without adding unnecessary operational complexity.</p><img class="about-photo" src="https://images.pexels.com/photos/33531806/pexels-photo-33531806.jpeg?auto=compress&cs=tinysrgb&w=1400" alt="Technician repairing a laptop in an electronics workshop" width="1200" height="720" loading="lazy" /></div><div class="principles"><article><h3>Practical</h3><p>Tools are judged by whether they remove repeat work and improve accuracy.</p></article><article><h3>Repairable</h3><p>Projects favor simple components, clear ownership, and documented decisions.</p></article><article><h3>Deployable</h3><p>Public work stays static, fast, and easy to ship on Cloudflare Pages.</p></article></div></div></section>
  <section class="section contact-strip"><div class="container contact-strip-inner"><div><h2>Retail site</h2><p>For product availability, service enquiries, and refurbished computer sales, use the main store.</p></div><a class="button" href={SITE.storeUrl} target="_blank" rel="noopener">xtremesystems.co.nz</a></div></section>
</BaseLayout>

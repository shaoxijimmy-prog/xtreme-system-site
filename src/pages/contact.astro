---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE } from '@lib/site';
---
<BaseLayout title="Contact" description="Contact XtremeSystem through the main Xtreme Systems retail website.">
  <section class="page-hero contact-hero"><div class="container contact-card"><img class="contact-card-image" src="https://images.pexels.com/photos/29238152/pexels-photo-29238152.jpeg?auto=compress&cs=tinysrgb&w=1400" alt="Modern technology desk with laptop and storage devices" width="1200" height="720" loading="lazy" /><h1>Contact</h1><p>For refurbished computer sales, service requests, product availability, and retail enquiries, head to the main Xtreme Systems website.</p><div class="hero-actions"><a class="button" href={SITE.storeUrl} target="_blank" rel="noopener">Open xtremesystems.co.nz</a><a class="button button-ghost" href="/projects/">Browse projects</a></div></div></section>
</BaseLayout>

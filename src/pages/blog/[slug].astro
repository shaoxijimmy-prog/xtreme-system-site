---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}
const { post } = Astro.props;
const { Content } = await render(post);
const date = new Intl.DateTimeFormat('en-NZ', { day: 'numeric', month: 'long', year: 'numeric' }).format(post.data.pubDate);
const categoryImages: Record<string, string> = {
  Automation: 'https://images.pexels.com/photos/33531806/pexels-photo-33531806.jpeg?auto=compress&cs=tinysrgb&w=1600',
  Homelab: 'https://images.pexels.com/photos/5480781/pexels-photo-5480781.jpeg?auto=compress&cs=tinysrgb&w=1600',
  Hardware: 'https://images.pexels.com/photos/2582934/pexels-photo-2582934.jpeg?auto=compress&cs=tinysrgb&w=1600',
  'AI Lab': 'https://images.pexels.com/photos/10782402/pexels-photo-10782402.jpeg?auto=compress&cs=tinysrgb&w=1600',
  'Buying Guide': 'https://images.pexels.com/photos/13279384/pexels-photo-13279384.jpeg?auto=compress&cs=tinysrgb&w=1600'
};
const primaryCategory = post.data.categories[0] ?? '';
const coverImage = post.data.image ?? categoryImages[primaryCategory] ?? 'https://images.pexels.com/photos/29238152/pexels-photo-29238152.jpeg?auto=compress&cs=tinysrgb&w=1600';
const coverAlt = post.data.imageAlt ?? `${post.data.title} article image`;
---
<BaseLayout title={post.data.title} description={post.data.description} image={coverImage}>
  <article class="article"><header class="article-header container"><a class="text-link" href="/blog/">Back to blog</a><h1>{post.data.title}</h1><p>{post.data.description}</p><img class="article-cover" src={coverImage} alt={coverAlt} width="1200" height="675" loading="eager" /><div class="article-meta"><time datetime={post.data.pubDate.toISOString()}>{date}</time><span>{post.data.author}</span></div></header><div class="container prose"><Content /></div></article>
</BaseLayout>

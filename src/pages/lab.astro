---
import BaseLayout from '@layouts/BaseLayout.astro';
import LabUpdate from '@components/LabUpdate.astro';
import { labUpdates } from '@data/labUpdates';
---
<BaseLayout title="Lab" description="XtremeSystem lab updates covering local AI, TrueNAS storage, monitoring nodes, and refurbished hardware testing."><section class="page-hero lab-hero"><div class="container lab-hero-grid"><div><h1>Lab</h1><p>Small infrastructure experiments that support the retail floor and keep project decisions grounded in real hardware.</p></div><img src="/images/hero-lab.svg" alt="XtremeSystem homelab and refurbished computer bench" width="1200" height="720" loading="lazy" /></div></section><section class="section"><div class="container lab-page-grid"><div class="lab-list">{labUpdates.map((update) => <LabUpdate {...update} />)}</div><aside class="lab-aside"><h2>Current Focus</h2><ul><li>Local AI product workflow testing</li><li>TrueNAS storage and snapshot policy</li><li>Raspberry Pi monitoring node telemetry</li><li>Refurbished workstation validation</li></ul></aside></div></section></BaseLayout>

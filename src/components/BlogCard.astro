---
import type { CollectionEntry } from 'astro:content';
interface Props { post: CollectionEntry<'blog'>; }
const { post } = Astro.props;
const date = new Intl.DateTimeFormat('en-NZ', { day: 'numeric', month: 'short', year: 'numeric' }).format(post.data.pubDate);
const categoryImages: Record<string, string> = {
  Automation: 'https://images.pexels.com/photos/33531806/pexels-photo-33531806.jpeg?auto=compress&cs=tinysrgb&w=1200',
  Homelab: 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=1200&q=80',
  Hardware: 'https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=1200&q=80',
  'AI Lab': 'https://images.unsplash.com/photo-1517420704952-d9f39e95b43e?auto=format&fit=crop&w=1200&q=80',
  'Buying Guide': 'https://images.unsplash.com/photo-1593642532973-d31b6557fa68?auto=format&fit=crop&w=1200&q=80'
};
const primaryCategory = post.data.categories[0] ?? '';
const cardImage = post.data.image ?? categoryImages[primaryCategory] ?? 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=1200&q=80';
const cardImageAlt = post.data.imageAlt ?? `${post.data.title} article image`;
---
<article class:list={['blog-card', { 'has-image': true }]}>
  <img class="blog-card-image" src={cardImage} alt={cardImageAlt} width="520" height="330" loading="lazy" />
  <div class="blog-card-meta"><time datetime={post.data.pubDate.toISOString()}>{date}</time>{post.data.categories[0] && <span>{post.data.categories[0]}</span>}</div>
  <div><h3><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3><p>{post.data.description}</p></div>
</article>

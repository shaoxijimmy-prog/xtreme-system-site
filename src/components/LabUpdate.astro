---
interface Props { date: string; title: string; summary: string; href?: string; }
const { date, title, summary, href } = Astro.props;
const formatted = new Intl.DateTimeFormat('en-NZ', { day: 'numeric', month: 'short', year: 'numeric' }).format(new Date(date));
---
<article class="lab-update"><time datetime={date}>{formatted}</time><div><h3>{href ? <a href={href}>{title}</a> : title}</h3><p>{summary}</p></div></article>
